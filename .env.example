VITE_KAKAO_CLIENT_ID=
VITE_KAKAO_REDIRECT_URI=http://localhost:3000/login

# 네이버 로그인 클라이언트 ID(공개값). 네이버 개발자센터 앱 등록 후 발급.
# 미설정이면 로그인 화면에 네이버 버튼이 노출되지 않는다(isNaverConfigured 게이팅).
VITE_NAVER_CLIENT_ID=

# 미디어(사진/영상) 업로드용 R2 프리사인 발급 Worker 주소.
# 비워두는 걸 권장 — 코드(src/api/media.js)에 운영 Worker 기본값이 이미 박혀 있어 로컬에서 바로 동작함.
# 별도 Worker를 쓰고 싶을 때만 오버라이드.
# VITE_MEDIA_PRESIGN_URL=
